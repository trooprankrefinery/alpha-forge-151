# Copy to .env for local development. Never commit .env.
#
# Local online testing with paper IBKR:
# - Win11/WSL2 + Windows TWS uses host.docker.internal.
# - macOS with local TWS/Gateway uses 127.0.0.1.
# - 127.0.0.1 from WSL points to WSL itself, not Windows TWS.
# - Add the WSL IP from `hostname -I` to TWS trusted IPs.
# - Pick a fresh unused client id for every live smoke run.

QP__BROKER__HOST=host.docker.internal
# QP__BROKER__HOST=127.0.0.1
QP__BROKER__PORT=7497
# Docker workers use explicit Docker broker coordinates so host-local
# QP__BROKER__* values do not accidentally reroute containers.
QP__DOCKER_BROKER_HOST=host.docker.internal
QP__DOCKER_BROKER_PORT=7497
QP__BROKER__CLIENT_ID=985
QP__BROKER__ACCOUNT_ID=
QP__BROKER__PAPER_TRADING=true
QP__BROKER__REQUEST_TIMEOUT_SECONDS=30.0
QP__BROKER__STALE_GTC_CLEANUP_MINUTES=0

# Live smoke tests, live probes, AND the operator API broker-sync load this
# internal instrument map so broker positions resolve from IB conId ->
# platform instrument_id. Without it the console shows 0 positions even when
# the account holds some. broker-sync reads this from os.environ directly, so
# the native serve script (scripts/serve_api_native.*) exports it from .env
# into the process env. Point at your traded universe for full position
# mapping, e.g. infra/config/universe_300.json.
QP__LIVE_IBKR__CONTRACTS_FILE=infra/config/live_contracts.example.json

# Optional live historical-bar smoke contract. Supply symbol and conId together.
# QP__LIVE_IBKR__TEST_SYMBOL=AAPL
# QP__LIVE_IBKR__TEST_EXCHANGE=SMART
# QP__LIVE_IBKR__TEST_CURRENCY=USD
# QP__LIVE_IBKR__TEST_CON_ID=265598

# make verify-online always enables read-only live IBKR smoke tests.
# make verify skips them unless explicitly enabled.
# QP_VERIFY_LIVE_IBKR=1

# Optional when ibapi is not already installed.
# IBAPI_PACKAGE_PATH=<path-to-TWS-API>/source/pythonclient

# Skip docker compose startup when Postgres/Redis are managed externally.
# QP_ONLINE_SKIP_DOCKER=1

# Required by docker-compose.yml; create a local .env and set a strong value.
POSTGRES_PASSWORD=change_me_before_running_compose

# Local durable paper-soak defaults.
QP__STORAGE__POSTGRES_DSN=postgresql+psycopg://quant:change_me_before_running_compose@localhost:5432/quant_platform
QP__STORAGE__REDIS_URL=redis://localhost:6379/0
QP__STORAGE__EVENT_BUS_BACKEND=redis_streams
QP__STORAGE__OBJECT_STORE_ROOT=./data/parquet
QP__STORAGE__POSTGRES_POOL_MIN=2
QP__STORAGE__POSTGRES_POOL_MAX=10

# V2 unified engine runtime / account orchestrator (ADR-014). When enabled,
# single-engine `supervise` runs as the N=1 case of the multi-engine path and
# writes the governance/read-model rows the operator console Strategy screen
# reads (strategy runs, engine budgets, source contributions). Also required by
# `run-multi-engine`. Leave false for the legacy single-engine V1 path.
QP__V2__ENABLED=false
QP__V2__ACCOUNT_ORCHESTRATOR_ENABLED=false

# Optional LLM text features. Default provider is Anthropic; set
# ANTHROPIC_API_KEY when enabling LLM shadow/live text features. To use
# DeepSeek instead, set DEEPSEEK_API_KEY and switch these values:
# QP__LLM__PROVIDER=deepseek
# QP__LLM__MODEL=deepseek-v4-flash
# ANTHROPIC_API_KEY=
# DEEPSEEK_API_KEY=
QP__LLM__PROVIDER=anthropic
QP__LLM__MODEL=claude-sonnet-4-6
QP__LLM__DEEPSEEK_BASE_URL=https://api.deepseek.com/anthropic
QP__LLM__MAX_TOKENS=1000
QP__LLM__SHADOW_MODE_ENABLED=false
QP__LLM__LIVE_MODE_ENABLED=false
QP__LLM__LIVE_REHEARSAL_ENABLED=false

# Optional data-feed API keys (research and ingest paths). Use the
# QP__DATA_INGEST__ prefix — these are pydantic-settings-managed
# values, not raw module-level env reads.
# - Tiingo + Polygon power the daily bar fetchers in
#   ``services/data_service/feeds/``. Either is sufficient; the failover
#   fetcher uses both when present.
# - Nasdaq Data Link gates ``scripts/pull_sharadar_sf1.py`` (Sharadar Core
#   US Equities fundamentals — SF1/SEP/TICKERS). Required only when
#   running the fundamentals-v1 feature family or its starter scripts.
# QP__DATA_INGEST__TIINGO_API_TOKEN=
# QP__DATA_INGEST__POLYGON_API_KEY=
# QP__DATA_INGEST__NASDAQ_DATA_LINK_API_KEY=

QP__RISK__HALT_ON_STALE_FEATURES=false
QP__RISK__ETF_CORRELATION_GROUPS={}
QP__RISK__ETF_GROUP_CAP_MULTIPLIER=1.5
QP__DATA_INGEST__MAX_BAR_AGE_MINUTES=60
